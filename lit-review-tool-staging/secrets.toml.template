# .streamlit/secrets.toml
# Copy this file to .streamlit/secrets.toml (drop the .template extension)
# and fill in your values. Never commit the real secrets.toml to git.
# On Streamlit Community Cloud, paste these into the Secrets panel.

# Required — Neon Postgres connection string (use the POOLED endpoint).
# Find at: console.neon.tech → your project → Connection details → "Pooled connection"
NEON_DATABASE_URL = "postgresql://user:password@ep-xxx-pooler.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Optional — gate the app behind a password. Leave blank to disable.
LIT_REVIEW_PASSWORD = "your-password-here"

# Optional — enables ✨ Clean / Suggest tags / Generate summary / 🤔 Explain. Hidden if blank.
ANTHROPIC_API_KEY = "sk-ant-..."
